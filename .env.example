##############################################################################
# PROJECT NEBULA — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
##############################################################################

# --- Environment ----------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=nebula
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nebula_db

# --- AI APIs --------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Replicate — default audio backend (MusicGen Stereo Large, ~$0.008/stem)
# Get token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# Replicate model for music generation.
# If you get 404 errors, check https://replicate.com/explore?category=audio
# for the current correct model slug and update this value.
REPLICATE_MODEL=meta/musicgen

# Gemini — optional fallback when experimental models (Lyria/Imagen/Veo) reach GA
# Leave empty if using default providers (replicate / dalle3 / ffmpeg)
GEMINI_API_KEY=

# --- Media Provider Selection ---------------------------------------------
# Swap providers without touching code. Defaults shown below.
#
#   AUDIO_PROVIDER:  replicate  → MusicGen Stereo Large via Replicate API
#                    gemini     → Lyria 3 via Gemini API (experimental)
#
#   IMAGE_PROVIDER:  dalle3     → DALL-E 3 via OpenAI API (~$0.080/image HD)
#                    gemini     → Imagen 3 via Gemini API (experimental)
#
#   VIDEO_PROVIDER:  ffmpeg     → Ken Burns animation from DALL-E image (FREE)
#                    gemini     → Veo 2 via Gemini API (experimental)
#
AUDIO_PROVIDER=replicate
IMAGE_PROVIDER=dalle3
VIDEO_PROVIDER=ffmpeg

# --- Social / Distribution APIs ------------------------------------------
# YouTube Data API v3
# Step 1: Download client secrets from Google Cloud Console
#         → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop)
#         → save as ./secrets/youtube_client_secrets.json
YOUTUBE_CLIENT_SECRETS_FILE=/secrets/youtube_client_secrets.json
# Step 2: Run once locally to authorise and generate the token:
#         python scripts/youtube_auth.py
#         → saves ./secrets/youtube_token.json (mount into container)
YOUTUBE_TOKEN_FILE=/secrets/youtube_token.json

TIKTOK_API_KEY=CHANGE_ME

# --- Celery Worker Tuning -------------------------------------------------
ORCHESTRATOR_CONCURRENCY=4
DSP_CONCURRENCY=2
DSP_CPU_LIMIT=4.0
DSP_MEM_LIMIT=8G
VIDEO_CONCURRENCY=2
FFMPEG_HWACCEL=auto        # auto | nvenc | vaapi | none

# --- CrewAI / LLM ---------------------------------------------------------
CREWAI_VERBOSE=false

# LLM model for CrewAI agents (any LiteLLM-compatible model string).
# gpt-4o-mini is ~16x cheaper than gpt-4o and handles all tasks well.
# Switch to gpt-4o or claude-sonnet-4-6 if you want higher quality output.
LLM_MODEL=gpt-4o-mini
LLM_PRECISE_MODEL=gpt-4o-mini

# --- Flower Monitoring ----------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD
